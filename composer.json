{
  "name": "chijioke-ibekwe/raven",
  "description": "Multi-channel Laravel notification sender",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "sendgrid",
    "notifications",
    "sendgrid-api",
    "laravel-package"
  ],
  "authors": [
    {
      "name": "Chijioke Ibekwe",
      "email": "ibekwe.chijioke18@gmail.com"
    }
  ],
  "homepage": "https://github.com/chijioke-ibekwe/raven",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/notifications": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
    "sendgrid/sendgrid": "~7",
    "aws/aws-sdk-php": "^3.300",
    "phpmailer/phpmailer": "^6.9",
    "vonage/client": "^4.0",
    "twilio/sdk": "^8.11",
    "wildbit/postmark-php": "^7.0",
    "guzzlehttp/guzzle": "^7.10",
    "mailgun/mailgun-php": "^4.4",
    "nyholm/psr7": "^1.8"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "phpunit/phpunit": "^10.5|^11.0",
    "laravel/pint": "^1.0",
    "larastan/larastan": "^2.0|^3.0"
  },
  "autoload": {
    "psr-4": {
      "ChijiokeIbekwe\\Raven\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ChijiokeIbekwe\\Raven\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "pint": "vendor/bin/pint",
    "stan": "vendor/bin/phpstan analyse"
  },
  "extra": {
    "laravel": {
      "providers": [
        "ChijiokeIbekwe\\Raven\\RavenServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
